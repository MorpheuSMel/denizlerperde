@page
@model PerdeProje.Pages.CalisanPanelModel
@{
    ViewData["Title"] = Model.PanelBasligi;
}

<style>
    .staff-page {
        max-width: 1180px;
        margin: 42px auto;
        padding: 0 20px;
        color: #4f4038;
    }

    .staff-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 18px;
        margin-bottom: 26px;
    }

    .staff-title {
        font-size: 2rem;
        font-weight: 800;
        color: #6f5343;
        margin: 0;
    }

    .staff-note {
        margin: 8px 0 0;
        color: #7a716d;
    }

    .logout-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
        min-width: 128px;
        height: 44px;
        padding: 0 18px;
        border: 1px solid #6f5343;
        border-radius: 10px;
        background: #6f5343;
        color: #fff;
        text-decoration: none;
        font-weight: 800;
        box-shadow: 0 10px 22px rgba(80, 55, 42, 0.14);
    }

    .logout-button:hover {
        color: #fff;
        background: #553c30;
        border-color: #553c30;
    }

    .staff-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 18px;
    }

    .task-card {
        background: #fff;
        border: 1px solid #eadfd6;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 10px 24px rgba(80, 55, 42, 0.08);
    }

    .task-card h3 {
        margin: 0 0 8px;
        color: #6f5343;
        font-size: 1.15rem;
    }

    .task-meta {
        display: grid;
        gap: 6px;
        color: #5f5651;
        margin: 12px 0 16px;
        font-size: 0.95rem;
    }

    .status-pill {
        display: inline-flex;
        width: fit-content;
        padding: 6px 10px;
        border-radius: 999px;
        background: #f3e7dc;
        color: #6f5343;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .task-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .task-actions button {
        border: 0;
        border-radius: 6px;
        padding: 9px 12px;
        background: #6f5343;
        color: #fff;
        font-weight: 700;
        cursor: pointer;
    }

    .empty-state {
        background: linear-gradient(135deg, #fff 0%, #fbf6ef 100%);
        border: 1px solid #eadfd6;
        border-radius: 18px;
        padding: 44px 28px;
        text-align: center;
        color: #6f5343;
        box-shadow: 0 16px 34px rgba(80, 55, 42, 0.08);
        min-height: 220px;
        display: grid;
        place-items: center;
    }

    .empty-state-inner {
        max-width: 460px;
    }

    .empty-icon {
        width: 58px;
        height: 58px;
        margin: 0 auto 16px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: #f3e0c8;
        color: #6f5343;
        font-size: 1.45rem;
        font-weight: 900;
    }

    .empty-title {
        margin: 0 0 8px;
        font-size: 1.25rem;
        font-weight: 800;
    }

    .empty-text {
        margin: 0;
        color: #8a7a70;
        line-height: 1.6;
    }

    @@media (max-width: 640px) {
        .staff-header {
            flex-direction: column;
        }

        .logout-button {
            width: 100%;
        }
    }
</style>

<main class="staff-page">
    <section class="staff-header">
        <div>
            <h1 class="staff-title">@Model.PanelBasligi</h1>
            <p class="staff-note">Bu ekranda sadece sizin görevinize düşen işler görünür.</p>
        </div>
        
    </section>

    @if (Model.Rol.Equals("Montajci", StringComparison.OrdinalIgnoreCase))
    {
        @if (Model.Randevular.Count == 0 && Model.Siparisler.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-inner">
                    <div class="empty-icon">✓</div>
                    <h2 class="empty-title">Şu anda atanmış iş yok</h2>
                    <p class="empty-text">Yeni montaj veya ölçü işi geldiğinde bu ekranda otomatik görünecek.</p>
                </div>
            </div>
        }
        else
        {
            <section class="staff-grid">
                @foreach (var randevu in Model.Randevular)
                {
                    <article class="task-card">
                        <span class="status-pill">@randevu.DurumEtiketi</span>
                        <h3>@randevu.MusteriAdi</h3>
                        <div class="task-meta">
                            <span><strong>Perde:</strong> @randevu.PerdeTuru</span>
                            <span><strong>Tarih/Saat:</strong> @randevu.Olcu</span>
                            <span><strong>Adres/Not:</strong> @randevu.PileTipi</span>
                        </div>
                        <form method="post" asp-page-handler="RandevuDurum" class="task-actions">
                            <input type="hidden" name="id" value="@randevu.Id" />
                            <button type="submit" name="durum" value="Montaj Planlandı">Montaj Planlandı</button>
                            <button type="submit" name="durum" value="Montaj Tamamlandı">Montaj Tamamlandı</button>
                        </form>
                    </article>
                }

                @foreach (var siparis in Model.Siparisler)
                {
                    <article class="task-card">
                        <span class="status-pill">@PerdeProje.Pages.CalisanPanelModel.GorunenDurum(siparis.Durum)</span>
                        <h3>@siparis.UrunAdi</h3>
                        <div class="task-meta">
                            <span><strong>Sipariş Kodu:</strong> @siparis.SiparisKodu</span>
                            <span><strong>Tarih:</strong> @siparis.SiparisTarihi.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <form method="post" asp-page-handler="SiparisDurum" class="task-actions">
                            <input type="hidden" name="id" value="@siparis.Id" />
                            <button type="submit" name="durum" value="Teslimat Başladı">Montaja Başla</button>
                            <button type="submit" name="durum" value="Teslim Edildi">Montaj Tamamlandı</button>
                        </form>
                    </article>
                }
            </section>
        }
    }
    else
    {
        @if (Model.Siparisler.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-inner">
                    <div class="empty-icon">✓</div>
                    <h2 class="empty-title">Şu anda atanmış sipariş yok</h2>
                    <p class="empty-text">Bir önceki birim işi size gönderdiğinde sipariş kartları burada listelenecek.</p>
                </div>
            </div>
        }
        else
        {
            <section class="staff-grid">
                @foreach (var siparis in Model.Siparisler)
                {
                    <article class="task-card">
                        <span class="status-pill">@PerdeProje.Pages.CalisanPanelModel.GorunenDurum(siparis.Durum)</span>
                        <h3>@siparis.UrunAdi</h3>
                        <div class="task-meta">
                            <span><strong>Sipariş Kodu:</strong> @siparis.SiparisKodu</span>
                            <span><strong>Tarih:</strong> @siparis.SiparisTarihi.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <form method="post" asp-page-handler="SiparisDurum" class="task-actions">
                            <input type="hidden" name="id" value="@siparis.Id" />
                            @if (Model.AkilliSistemciMi)
                            {
                                <button type="submit" name="durum" value="Paketlemeye Hazır">Paketlemeye Yolla</button>
                                <button type="submit" name="hedef" value="Paketleme" hidden></button>
                            }
                            else if (Model.PaketlemeciMi)
                            {
                                <button type="submit" name="durum" value="Paketlendi">Paketlendi</button>
                                <button type="submit" name="hedef" value="Kargo" hidden></button>
                            }
                            else if (Model.KargocuMu)
                            {
                                <button type="submit" name="durum" value="Kargoya Verildi">Kargoya Verildi</button>
                            }
                            else
                            {
                                <button type="submit" name="durum" value="Dikime Alındı">Dikime Alındı</button>
                                <button type="submit" name="durum" value="Dikim Tamamlandı">Dikim Tamamlandı</button>
                                <button type="submit" name="durum" value="Montaja Hazır">Montaja Hazır</button>
                                <button type="submit" name="durum" value="Paketlemeye Hazır">Paketlemeye Yolla</button>
                            }
                        </form>
                    </article>
                }
            </section>
        }
    }
</main>




