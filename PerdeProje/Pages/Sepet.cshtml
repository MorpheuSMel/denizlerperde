@page
@model PerdeProje.Pages.SepetModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Sepet";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold" style="color:#6b5344;">Sepetim</h1>
        <a href="/Satis" class="btn btn-outline-secondary">Alisverise Don</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Mesaj))
    {
        <div class="alert alert-success">@Model.Mesaj</div>
    }

    @if (Model.Urunler.Any())
    {
        <div class="card border-0 shadow-sm" style="border-radius:16px;">
            <div class="card-body">
                @foreach (var urun in Model.Urunler)
                {
                    <div class="d-flex gap-3 align-items-center py-3 border-bottom">
                        <img src="@urun.ResimUrl" alt="@urun.Ad" style="width:96px;height:72px;object-fit:cover;border-radius:10px;">
                        <div class="flex-grow-1">
                            <h5 class="mb-1">@urun.Ad</h5>
                            <div class="text-muted small">@urun.Kategori</div>
                        </div>
                        <strong style="color:#6b5344;">₺@urun.Fiyat.ToString("N2")</strong>
                        <form method="post" asp-page-handler="Sil" asp-route-id="@urun.Id" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:10px;">Sil</button>
                        </form>
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center pt-4">
                    <form method="post" asp-page-handler="Temizle">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger">Sepeti Temizle</button>
                    </form>
                    <div class="text-end">
                        <div class="text-muted">Toplam</div>
                        <div class="fs-3 fw-bold" style="color:#6b5344;">₺@Model.ToplamTutar.ToString("N2")</div>
                    </div>
                </div>

                <form method="post" action="/Sepet?handler=SiparisOlustur" class="mt-4 p-4 bg-light" style="border-radius:16px;">
                    @Html.AntiForgeryToken()
                    <h4 class="fw-bold mb-3" style="color:#6b5344;">Teslimat ve Odeme Bilgileri</h4>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Teslimat Adresi</label>
                        <textarea id="TeslimatAdresi" name="TeslimatAdresi" class="form-control" rows="3" placeholder="Mahalle, sokak, bina no, daire, ilce/il" required style="border-radius:12px;">@Model.TeslimatAdresi</textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Kargo Notu</label>
                        <input id="KargoNotu" name="KargoNotu" value="@Model.KargoNotu" class="form-control" placeholder="Orn: Aramadan gelmeyin, kapiciya birakilabilir..." style="border-radius:12px;" />
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Kart Uzerindeki Isim</label>
                            <input id="KartUzerindekiIsim" name="KartUzerindekiIsim" value="@Model.KartUzerindekiIsim" class="form-control" placeholder="AD SOYAD" required style="border-radius:12px;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Kart Numarasi</label>
                            <input id="KartNumarasi" name="KartNumarasi" value="@Model.KartNumarasi" class="form-control card-number-mask" placeholder="0000 0000 0000 0000" maxlength="19" inputmode="numeric" required style="border-radius:12px;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Son Kullanma Tarihi</label>
                            <input id="SonKullanmaTarihi" name="SonKullanmaTarihi" value="@Model.SonKullanmaTarihi" class="form-control expiry-mask" placeholder="AA/YY" maxlength="5" inputmode="numeric" required style="border-radius:12px;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">CVV</label>
                            <input id="Cvv" name="Cvv" value="@Model.Cvv" class="form-control cvv-mask" placeholder="123" maxlength="3" inputmode="numeric" required style="border-radius:12px;" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn text-white px-4 py-2" style="background-color:#6b5344; border-radius:12px;">Siparisi Onayla</button>
                    </div>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="text-center bg-white shadow-sm p-5" style="border-radius:16px;">
            @if (!string.IsNullOrWhiteSpace(Model.Mesaj) && Model.Mesaj.Contains("al", StringComparison.OrdinalIgnoreCase))
            {
                <div class="alert alert-success border-0 fw-bold mb-4" style="border-radius:14px;">
                    @Model.Mesaj
                </div>
            }
            <h4 class="fw-bold" style="color:#6b5344;">Sepetiniz bos</h4>
            <p class="text-muted">Begendiginiz urunleri satis sayfasindan sepete ekleyebilirsiniz.</p>
            <a href="/Satis" class="btn text-white" style="background-color:#6b5344;">Urunlere Git</a>
        </div>
    }
</div>

<script>
    document.querySelectorAll('.card-number-mask').forEach(function (input) {
        function formatCard() {
            const digits = input.value.replace(/\D/g, '').slice(0, 16);
            input.value = (digits.match(/.{1,4}/g) || []).join(' ');
        }

        input.addEventListener('input', formatCard);
        formatCard();
    });

    document.querySelectorAll('.expiry-mask').forEach(function (input) {
        function formatExpiry() {
            const digits = input.value.replace(/\D/g, '').slice(0, 4);
            input.value = digits.length > 2 ? digits.slice(0, 2) + '/' + digits.slice(2) : digits;
        }

        input.addEventListener('input', formatExpiry);
        input.addEventListener('keydown', function (event) {
            if (event.key === 'Backspace' && input.value.length === 3) {
                input.value = input.value.slice(0, 2);
                event.preventDefault();
            }
        });
        formatExpiry();
    });

    document.querySelectorAll('.cvv-mask').forEach(function (input) {
        function formatCvv() {
            input.value = input.value.replace(/\D/g, '').slice(0, 3);
        }

        input.addEventListener('input', formatCvv);
        formatCvv();
    });
</script>
