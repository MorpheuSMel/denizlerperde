<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Denizler Perde</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body style="background-color: #fdfaf7;">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/" style="color: #6b5344; font-size: 1.4rem;">Denizler Perde & Tasarım</a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 justify-content-center gap-3">
                        <li class="nav-item"><a class="nav-link text-dark fw-semibold" href="/">Anasayfa</a></li>
                        <li class="nav-item"><a class="nav-link text-dark fw-semibold" href="#kategoriler">Ürünler</a></li>
                        <li class="nav-item"><a class="nav-link text-dark fw-semibold" href="/Iletisim">Randevu Sistemi</a></li>
                        <li class="nav-item"><a class="nav-link fw-bold" href="/Satis" style="color: #6b5344;">🛒 Satış Paneli</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted text-center py-3 bg-white mt-5">
        <div class="container">&copy; 2026 - Denizler Perde & Tasarım</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>