@model PerdeProje.Models.Urun
@using Microsoft.AspNetCore.Http
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Ad;
    var girisYapildi = !string.IsNullOrWhiteSpace(Context.Session.GetString("UserId"));
    var kategori = Model.Kategori ?? "";
    var olcuBasligi = kategori.Contains("Stor") || kategori.Contains("Zebra") || kategori.Contains("Blackout")
        ? "En x boy ölçüsü"
        : kategori.Contains("Fon") || kategori.Contains("Tül")
            ? "Korniş genişliği ve yükseklik"
            : "Pencere/duvar ölçüsü";
    var olcuDetayi = kategori.Contains("Stor") || kategori.Contains("Zebra") || kategori.Contains("Blackout")
        ? "Stor, zebra ve blackout perdelerde genişlik ile yükseklik net ölçü alınır. Mekanizma payı için sağ ve sol boşluk ayrıca kontrol edilir."
        : kategori.Contains("Fon")
            ? "Fon perdede korniş genişliği, bitiş yüksekliği ve istenen pile yoğunluğu ölçülür. Kartela seçimi randevuda netleştirilir."
            : kategori.Contains("Tül")
                ? "Tül perdede korniş genişliği, tavandan yere yükseklik ve pile sıklığı ölçülür. Zemine değme tercihi ayrıca belirlenir."
                : "Ürün tipine göre net pencere ölçüsü, montaj alanı ve mekanizma boşluğu kontrol edilir.";
}

<section class="py-5">
    <div class="container">
        <a href="/Products" class="btn btn-light mb-4" style="color:#6b5344; border-radius:12px;">← Ürünlere Dön</a>

        @if (TempData["Mesaj"] is string mesaj && !string.IsNullOrWhiteSpace(mesaj))
        {
            <div class="alert alert-success border-0 shadow-sm" style="border-radius:14px;">@mesaj</div>
        }

        <div class="row g-5 align-items-start">
            <div class="col-lg-6">
                <div class="bg-white shadow-sm p-3" style="border-radius:18px;">
                    <img src="@(string.IsNullOrWhiteSpace(Model.ResimUrl) ? "https://via.placeholder.com/800x600?text=Denizler+Perde" : Model.ResimUrl)" alt="@Model.Ad" class="w-100" style="height:430px; object-fit:cover; border-radius:14px;">
                    @if (!string.IsNullOrWhiteSpace(Model.IkinciResimUrl))
                    {
                        <div class="mt-3">
                            <img src="@Model.IkinciResimUrl" alt="@Model.Ad ikinci görsel" class="w-100" style="height:180px; object-fit:cover; border-radius:14px;">
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-6">
                <span class="badge mb-3" style="background:#6b5344;">@Model.Kategori</span>
                <h1 class="fw-bold mb-3" style="color:#4a3a2f;">@Model.Ad</h1>
                <p class="text-muted fs-5">@Model.Aciklama</p>

                <div class="d-flex align-items-end gap-3 my-4">
                    <div>
                        <div class="text-muted small">Fiyat</div>
                        <div class="fw-bold" style="font-size:2rem; color:#6b5344;">₺@Model.Fiyat.ToString("N2")</div>
                    </div>
                    <div class="text-muted pb-2">@Model.Stok adet stok</div>
                </div>

                <div class="bg-light p-4 mb-4" style="border-radius:16px;">
                    <h4 class="fw-bold mb-3" style="color:#6b5344;">Ölçü Bilgisi</h4>
                    <div class="mb-2"><strong>@olcuBasligi</strong></div>
                    <p class="text-muted mb-0">@olcuDetayi</p>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-sm-6">
                        <div class="detail-box">
                            <strong>Pile / Duruş</strong>
                            <span>Kullanım alanına göre normal, sık veya dekoratif pile önerilir.</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="detail-box">
                            <strong>Montaj</strong>
                            <span>Korniş, rustik, mekanizma veya jaluzi taşıyıcısına göre uygulanır.</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="detail-box">
                            <strong>Kumaş / Kartela</strong>
                            <span>Fon ve tül ürünlerinde renk/kumaş seçimi kartela üzerinden yapılabilir.</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="detail-box">
                            <strong>Randevu</strong>
                            <span>Net fiyat ve ölçü için yerinde keşif alınabilir.</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    @if (girisYapildi)
                    {
                        <form method="post" asp-controller="Products" asp-action="FavoriyeEkle" asp-route-id="@Model.Id" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn action-heart-btn px-4">
                                <i class="far fa-heart me-2"></i> Favorilere Ekle
                            </button>
                        </form>
                        <form method="post" asp-controller="Products" asp-action="SepeteEkle" asp-route-id="@Model.Id" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn cart-action-btn px-4">
                                <i class="fas fa-shopping-cart me-2"></i> Sepete Ekle
                            </button>
                        </form>
                    }
                    else
                    {
                        <a href="/Auth/Login" class="btn cart-action-btn px-4">Giriş Yap</a>
                    }
                    <a href="/Iletisim?model=@Uri.EscapeDataString(Model.Ad)" class="btn btn-light px-4" style="border-radius:14px; color:#6b5344;">Randevu Al</a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .detail-box {
        min-height: 118px;
        background: #fff;
        border: 1px solid #f0e7df;
        border-radius: 14px;
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .detail-box strong {
        color: #6b5344;
    }

    .detail-box span {
        color: #6c757d;
        font-size: 0.92rem;
    }

    .action-heart-btn {
        min-height: 46px;
        border-radius: 14px;
        border: 1px solid #eadfd7;
        background: #fff8f5;
        color: #9f4f4f;
        font-weight: 700;
    }

    .cart-action-btn {
        min-height: 46px;
        border-radius: 14px;
        background: linear-gradient(135deg, #6b5344 0%, #4a3a2f 100%);
        color: #fff;
        font-weight: 700;
        border: 0;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

    .cart-action-btn:hover {
        color: #fff;
    }
</style>
