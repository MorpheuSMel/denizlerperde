@model IEnumerable<PerdeProje.Models.Urun>
@using Microsoft.AspNetCore.Http
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Urunler";
    var girisYapildi = !string.IsNullOrWhiteSpace(Context.Session.GetString("UserId"));
}

<section class="section-white py-5">
    <div class="container">
        <h2 class="section-title text-center fw-bold mb-3" style="color: #6b5344; font-size: 2.2rem;">Perde Koleksiyonumuz</h2>
        <p class="text-center text-muted mx-auto mb-5" style="max-width: 600px;">
            Eviniz veya iş yerinizin stiline uygun perde seçeneklerini inceleyin. Zebra, fon, stor, tül ve motorlu sistemler tek katalogda.
        </p>

        @if (TempData["Mesaj"] is string mesaj && !string.IsNullOrWhiteSpace(mesaj))
        {
            <div class="alert alert-success border-0 shadow-sm mx-auto mb-4 d-flex justify-content-between align-items-center gap-3" style="max-width: 720px; border-radius: 12px;">
                <span>@mesaj</span>
                <a href="/Sepet" class="btn btn-sm text-white" style="background-color:#6b5344; border-radius:10px;">Sepete Git</a>
            </div>
        }

        <div class="row g-4">
            @foreach (var urun in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm p-3 card-hover-effect" style="border-radius: 20px; background-color: #ffffff;">
                        <div class="position-relative">
                            <img src="@(string.IsNullOrWhiteSpace(urun.ResimUrl) ? "https://via.placeholder.com/600x400?text=Denizler+Perde" : urun.ResimUrl)" alt="@urun.Ad" class="img-fluid rounded-4 w-100" style="height: 220px; object-fit: cover;" />
                            @if (!string.IsNullOrWhiteSpace(urun.IkinciResimUrl))
                            {
                                <img src="@urun.IkinciResimUrl" class="second-product-image" alt="@urun.Ad ikinci görsel">
                            }
                            <span class="position-absolute top-0 start-0 m-2 px-3 py-1 rounded-pill text-white small" style="background-color: rgba(107, 83, 68, 0.9);">@urun.Kategori</span>
                        </div>
                        <h5 class="mt-3 fw-bold text-dark">@urun.Ad</h5>
                        <p class="text-muted small flex-grow-1">@urun.Aciklama</p>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="fw-bold" style="color: #6b5344;">₺@urun.Fiyat.ToString("N2")</span>
                            <span class="text-muted small">@urun.Stok adet stok</span>
                        </div>
                        <div class="d-flex gap-2 mt-auto">
                            @if (girisYapildi)
                            {
                                <form method="post" asp-controller="Products" asp-action="FavoriyeEkle" asp-route-id="@urun.Id" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn action-heart-btn" title="Favorilere ekle">
                                        <i class="far fa-heart"></i>
                                    </button>
                                </form>
                                <form method="post" asp-controller="Products" asp-action="SepeteEkle" asp-route-id="@urun.Id" class="flex-grow-1 m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn cart-action-btn w-100">
                                        <i class="fas fa-shopping-cart me-2"></i> Sepete Ekle
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a class="btn action-heart-btn" title="Favorilere ekle" href="/Auth/Login">
                                    <i class="far fa-heart"></i>
                                </a>
                                <a class="btn cart-action-btn flex-grow-1" href="/Auth/Login">
                                    Giriş Yap
                                </a>
                            }
                        </div>
                        <a class="btn w-100 btn-light fw-semibold mt-2" style="color: #6b5344; border-radius: 12px;" href="/Iletisim?model=@Uri.EscapeDataString(urun.Ad)">Randevu Al</a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5" style="background: linear-gradient(135deg, #6b5344 0%, #4a3a2f 100%); color: #fff; border-radius: 0px;">
    <div class="container text-center py-3">
        <h2 style="color: #fff; margin-bottom: 1rem; font-weight: 700;">Doğru ürünü seçmekte yardıma ihtiyacınız var mı?</h2>
        <p style="color: rgba(255,255,255,0.9); margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">Uzman tasarımcılarımız mekanınızı ziyaret ederek, stilinize ve bütçenize uygun en iyi çözümü önerir.</p>
        <a class="btn bg-white px-4 py-2.5 fw-bold" style="color: #6b5344; border-radius: 12px;" href="/Iletisim">Ücretsiz Danışmanlık Talep Et</a>
    </div>
</section>

<style>
    .card-hover-effect {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .card-hover-effect:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(107, 83, 68, 0.1) !important;
    }

    .action-heart-btn {
        width: 46px;
        height: 44px;
        border-radius: 14px;
        border: 1px solid #eadfd7;
        background: #fff8f5;
        color: #9f4f4f;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

    .action-heart-btn:hover {
        background: #9f4f4f;
        border-color: #9f4f4f;
        color: #fff;
        transform: translateY(-1px);
    }

    .cart-action-btn {
        min-height: 44px;
        border-radius: 14px;
        background: linear-gradient(135deg, #6b5344 0%, #4a3a2f 100%);
        color: #fff;
        font-weight: 700;
        border: 0;
        box-shadow: 0 8px 18px rgba(107, 83, 68, 0.18);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .cart-action-btn:hover {
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 12px 22px rgba(107, 83, 68, 0.24);
    }

    .second-product-image {
        position: absolute;
        right: 12px;
        bottom: 12px;
        width: 78px;
        height: 62px;
        object-fit: cover;
        border: 3px solid #fff;
        border-radius: 12px;
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.24);
        background: #fff;
    }
</style>
